{
  "name": "translatorcat-2026",
  "version": "0.1.0",
  "description": "A tiny desktop cat that shows clipboard text in a speech bubble.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node scripts/start.cjs",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --dir"
  },
  "keywords": [
    "desktop-pet",
    "clipboard",
    "cat",
    "electron"
  ],
  "author": "obundh",
  "license": "MIT",
  "devDependencies": {
    "electron": "42.3.2",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "com.obundh.translatorcat2026",
    "productName": "TranslatorCat",
    "directories": {
      "output": "release"
    },
    "files": [
      "assets/**/*",
      "electron/**/*",
      "index.html",
      "renderer.js",
      "styles.css",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false,
      "artifactName": "TranslatorCat-${version}-${arch}.${ext}"
    },
    "asarUnpack": [
      "node_modules/onnxruntime-node/**/*"
    ]
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
